{
  "_comment": "File access policy for claude-hardening. Changes take effect immediately — no restart needed.",

  "sandboxMode": "standard",

  "blockedDirs": [
    ".vault",
    "secrets"
  ],

  "blockedFiles": [
    "*.secret"
  ],

  "blockedAbsolute": [],

  "allowedPaths": [
    "~/.ssh/known_hosts"
