{
  "_comment": "Strict profile — maximum restrictions. Suitable for untrusted code, security reviews, or when running Claude in production environments.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/sandbox-exec.js\""
          }
        ],
        "description": "Sandbox Bash commands via bwrap (strict mode — read-only base, writable allowlist)",
        "id": "pre:bash:sandbox-exec"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/deny-destructive.js\""
          }
        ],
        "description": "Block destructive commands",
        "id": "pre:bash:deny-destructive"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/network-egress.js\""
          }
        ],
        "description": "Block outbound network to domains not in allowlist",
        "id": "pre:bash:network-egress"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/git-guard.js\""
          }
        ],
        "description": "Block direct commits or pushes to main/master",
        "id": "pre:bash:git-guard"
      },
      {
        "matcher": "Bash|Read|Write|Edit|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/file-access.js\""
          }
        ],
        "description": "Block access to sensitive files",
        "id": "pre:file:file-access"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/secret-scan.js\""
          }
        ],
        "description": "Block writes containing credential patterns",
        "id": "pre:file:secret-scan"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/audit-log.js\""
          }
        ],
        "description": "Append all tool use entries to ~/.claude/audit.log",
        "id": "post:all:audit-log"
      }
    ]
  }
}
