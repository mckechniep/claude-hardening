{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/sandbox-exec.js\""
          }
        ],
        "description": "Sandbox Bash commands via bwrap (OS-level filesystem protection)",
        "id": "pre:bash:sandbox-exec"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/deny-destructive.js\""
          }
        ],
        "description": "Block destructive commands (rm -rf /, sudo, force push, etc.)",
        "id": "pre:bash:deny-destructive"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/network-egress.js\""
          }
        ],
        "description": "Block outbound network requests to domains not in allowlist",
        "id": "pre:bash:network-egress"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/git-guard.js\""
          }
        ],
        "description": "Warn on direct commits or pushes to main/master",
        "id": "pre:bash:git-guard"
      },
      {
        "matcher": "Bash|Read|Write|Edit|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/file-access.js\""
          }
        ],
        "description": "Block access to sensitive files (.env, .ssh, credentials, etc.)",
        "id": "pre:file:file-access"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/secret-scan.js\""
          }
        ],
        "description": "Block writes containing credential patterns (API keys, tokens, private keys)",
        "id": "pre:file:secret-scan"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"CLAUDE_DIR/scripts/hooks/audit-log.js\""
          }
        ],
        "description": "Append tool use entries to ~/.claude/audit.log",
        "id": "post:all:audit-log"
      }
    ]
  }
}
